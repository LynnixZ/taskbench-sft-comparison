# Copy to a private location and `source` it before running scripts/run_smoke_4090.sh.
# NEVER commit your real tokens. This file is a template only.

# --- Hugging Face (required: Llama-2 is gated) ---
export HF_TOKEN="hf_xxx_your_read_token"
export MODEL_NAME="meta-llama/Llama-2-7b-chat-hf"

# --- Where to work / store results (optional; sensible defaults exist) ---
export WORK_DIR="$HOME/taskbench_smoke_work"
export OUTPUT_DIR="$WORK_DIR/outputs_smoke_gpu"
export HF_HOME="$WORK_DIR/hf_home"

# --- Repo to clone (optional; omit to run from the current checkout) ---
# export EXPERIMENT_REPO_URL="https://github.com/<you>/<repo>.git"
# export EXPERIMENT_REPO_BRANCH="main"

# --- Stable id so resubmits resume W&B runs instead of duplicating them ---
export EXPERIMENT_RUN_ID="smoke-$(date -u +%Y%m%d)"

# --- Weights & Biases (key required for online mode; else auto-offline) ---
export WANDB_API_KEY="your_wandb_key"
export WANDB_ENTITY="your_entity"
export WANDB_PROJECT="taskbench-sft-smoke"
export WANDB_MODE="online"
export WANDB_RUN_GROUP="llama2-7b-4090-smoke"
