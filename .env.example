# Copy to a private location (e.g. ~/tb_env.sh), fill in your keys, then:
#   source ~/tb_env.sh && bash scripts/run_smoke_4090.sh
# NEVER commit your real tokens. This file is a template only.

# ============================================================
# UNIVERSAL (set on any machine, US or China)
# ============================================================
# Non-gated model -> no HF_TOKEN needed; Qwen3 reasoning auto-disabled by code.
export MODEL_NAME="Qwen/Qwen3-8B"
# For a gated model instead (needs license + token):
#   export MODEL_NAME="meta-llama/Llama-2-7b-chat-hf"
#   export HF_TOKEN="hf_xxx_your_read_token"

export WANDB_API_KEY="your_wandb_key"     # omit -> code auto-falls-back to offline
export WANDB_PROJECT="taskbench-sft-smoke"
export WANDB_RUN_GROUP="llama2-7b-4090-smoke"

# Put venv + model cache + outputs on a BIG disk (AutoDL: /root/autodl-tmp).
export WORK_DIR="/root/autodl-tmp/tb_work"
export HF_HOME="/root/autodl-tmp/hf_home"

# ============================================================
# CHINA ONLY -- DELETE THIS WHOLE BLOCK on a US/EU server
# ============================================================
export HF_ENDPOINT="https://hf-mirror.com"          # HF API/metadata via mirror
export HF_HUB_DISABLE_XET="1"                        # avoid weights going via the US Xet CDN
export PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
# Data download already prefers the global jsDelivr CDN; no extra var needed.
